#####################################################
#    Sensors in "Generate EMHASS energy plan mpc"
#
#.   Sensors:   
#    Energy_capacity: kWh
#    Chargin/discharging_power: W
#    Max inverter power: kw
#    Battery SOC: %
#    Consumed power = sensor no load var loads W
#    Current power = solar panel production W
#    electricity_price: Sek/kWh
#
#    The plan uses a forecast produced by EMHASS using ML predict and publish to sensor.p_load_forecast_ml 
#
#
####################################################

script:

  generate_emhass_energy_plan_mpc:
    alias: "generate EMHASS energy plan MPC"
    sequence:
      - variables:
          costfun: profit
          maximum_power_from_grid: 15000
          maximum_power_to_grid: 5000
          battery_minimum_percent: 20
        alias: Configure critical settings
      - variables:
          num_prediction_days: 2
          optimization_time_step: 15
          weight_battery_charge: 0.02
          weight_battery_discharge: 0.02
          sensor_prefix: mpc_pv_
          sensor_name_prefix: 'MPC_PV'
        alias: Configure secondary settings
      - variables:

          sensors:
            energy_capacity: sensor.solaredge_b1_maximum_energy
            charging_power: sensor.solaredge_b1_max_charge_power 
            discharging_power: sensor.solaredge_b1_max_discharge_power 
            max_inverter_power: sensor.max_active_power_1
            battery_soc: sensor.solaredge_b1_state_of_energy 
            consumed_power: sensor.power_myhouse_load_no_var_loads 
            solar:
              current_power: sensor.solar_panel_production_w 
              forecasts:
              - sensor.solcast_pv_forecast_forecast_today
              - sensor.solcast_pv_forecast_forecast_tomorrow
              - sensor.solcast_pv_forecast_forecast_day_3
            prices:
              import: sensor.nordpool_se3_total_costs_import
              export: sensor.nordpool_se3_total_revenue_export
        alias: Configure sensor entities

      - variables:
          num_forecasts: '{{ (60 / optimization_time_step * 24 * num_prediction_days) | int }}'
          soc_init: '{{ (states(sensors.battery_soc) | float(0) / 100) | round(3) }}'
          soc_final: '{{ battery_minimum_percent / 100 }}'
          now_iso: '{{ now().replace(microsecond=0).isoformat() }}'
          max_inverter_power: '{{ (states(sensors.max_inverter_power) | float(0) * 1000) | round }}'
          common:
            costfun: '{{ costfun }}'
            prediction_horizon: '{{ num_forecasts }}'
            optimization_time_step: '{{ optimization_time_step }}'
            delta_forecast_daily: '{{ num_prediction_days }}'
            set_use_adjusted_pv: false
            set_use_pv: true
            set_use_battery: true
            inverter_is_hybrid: true
            number_of_deferrable_loads: 0
            set_nodischarge_to_grid: false
            pv_power_forecast_method: 'list'
            load_cost_forecast_method: 'list'
            production_price_forecast_method: 'list'
          payload:
            weight_battery_charge: '{{ weight_battery_charge }}'
            weight_battery_discharge: '{{ weight_battery_discharge }}'
            battery_minimum_state_of_charge: '{{ battery_minimum_percent / 100 }}'
            battery_maximum_state_of_charge: 0.9
            battery_nominal_energy_capacity: '{{ (states(sensors.energy_capacity) | float(0) * 1000) | round }}'
            battery_charge_power_max: '{{ (states(sensors.charging_power) | float(0)) | round }}'
            battery_discharge_power_max: '{{ (states(sensors.discharging_power) | float(0)) | round }}'
            maximum_power_from_grid: '{{ maximum_power_from_grid }}'
            maximum_power_to_grid: '{{ maximum_power_to_grid }}'
            inverter_ac_output_max: '{{ max_inverter_power }}'
            inverter_ac_input_max: '{{ max_inverter_power }}'
            soc_init: '{{ soc_init }}'
            soc_final: '{{ soc_final }}'
            load_cost_forecast: |-
              {% set ns = namespace(output={}) %}
              {% for day in range(num_prediction_days) %}
                {% for forecast in (state_attr(sensors.prices.import, 'forecast_merged') or []) %}
                  {% set start = (forecast.ts.split(' - ')[0] | as_datetime | as_local + timedelta(days=day)).isoformat() %}
                  {% set price = forecast.price | float(0) %}
                  {% set ns.output = ns.output | combine({ start: price }) %}
                {% endfor %}
              {% endfor %}
              {{ ns.output }}

            prod_price_forecast: |-
              {% set ns = namespace(output={}) %}
              {% for day in range(num_prediction_days) %}
                {% for forecast in (state_attr(sensors.prices.export, 'forecast_merged') or []) %}
                  {% set start = (forecast.ts.split(' - ')[0] | as_datetime | as_local + timedelta(days=day)).isoformat() %}
                  {% set price = forecast.price | float(0) %}
                  {% set ns.output = ns.output | combine({ start: price }) %}
                {% endfor %}
              {% endfor %}
              {{ ns.output }}

            pv_power_forecast: |-
              {% set ns = namespace(
                input=sensors.solar.forecasts
                  | map('state_attr', 'detailedForecast')
                  | sum(start=[])
                  | selectattr('period_start', '>', now())
                  | selectattr('period_start', '<=', now() + timedelta(days=num_prediction_days)),
                output={
                  now_iso: (states(sensors.solar.current_power) | float(0)) | round(0)
                }
              ) %}
              {% for solar in ns.input %}
                {% set key = (solar.period_start | as_datetime | as_local).isoformat() %}
                {% set value = ((solar.pv_estimate | float(0)) * 1000) | round(0) %}
                {% set ns.output = ns.output | combine({ key: value }) %}
              {% endfor %}
              {{ ns.output }}
            load_power_forecast: |-
              {% set ml = state_attr('sensor.p_load_forecast_ml_pv', 'scheduled_forecast') or [] %}
              {% set ns = namespace(output={
                now_iso: (states(sensors.consumed_power) | float(0)) | round(0)
              }) %}
              {% for item in ml %}
                {% set ns.output = ns.output | combine({
                  item.date: (item.p_load_forecast_ml_pv | float(0)) | round(0)
                }) %}
              {% endfor %}
              {{ ns.output }}
        alias: Calculate payload
      - action: rest_command.emhass_naive_mpc_optim
        metadata: {}
        data:
          payload: >
            {{ dict(common, **payload) | to_json }}
        alias: Run EMHASS
      - variables:
          payload:
            custom_pv_forecast_id:
              entity_id: sensor.{{ sensor_prefix }}pv_power
              unit_of_measurement: W
              device_class: power
              friendly_name: '{{ sensor_name_prefix }}PV Power'
            custom_load_forecast_id:
              entity_id: sensor.{{ sensor_prefix }}load_power
              unit_of_measurement: W
              device_class: power
              friendly_name: '{{ sensor_name_prefix }}Load Power'
            custom_hybrid_inverter_id:
              entity_id: sensor.{{ sensor_prefix }}inverter_power
              unit_of_measurement: W
              device_class: power
              friendly_name: '{{ sensor_name_prefix }}Inverter Power'
            custom_batt_forecast_id:
              entity_id: sensor.{{ sensor_prefix }}batt_power
              unit_of_measurement: W
              device_class: power
              friendly_name: '{{ sensor_name_prefix }}Battery Power'
            custom_grid_forecast_id:
              entity_id: sensor.{{ sensor_prefix }}grid_power
              unit_of_measurement: W
              device_class: power
              friendly_name: '{{ sensor_name_prefix }}Grid Power'
            custom_batt_soc_forecast_id:
              entity_id: sensor.{{ sensor_prefix }}batt_soc
              unit_of_measurement: '%'
              device_class: battery
              friendly_name: '{{ sensor_name_prefix }}Battery SOC'
            custom_cost_fun_id:
              entity_id: sensor.{{ sensor_prefix }}cost_fun
              unit_of_measurement: $
              device_class: monetary
              friendly_name: '{{ sensor_name_prefix }}Cost Function'
            custom_unit_load_cost_id:
              entity_id: sensor.{{ sensor_prefix }}import_price
              unit_of_measurement: $
              device_class: monetary
              friendly_name: '{{ sensor_name_prefix }}Buy Price'
            custom_unit_production_price_id:
              entity_id: sensor.{{ sensor_prefix }}export_price
              unit_of_measurement: $
              device_class: monetary
              friendly_name: '{{ sensor_name_prefix }}Sell Price'
            custom_optim_status_id:
              entity_id: sensor.{{ sensor_prefix }}optim_status
              unit_of_measurement: ''
              friendly_name: '{{ sensor_name_prefix }}Optimisation Status'
      - action: rest_command.emhass_publish_data
        metadata: {}
        data:
          payload: >
            {{ dict(common, **payload) | to_json }}
        alias: Publish Energy Plan to HA
  alias: Generate EMHASS Energy Plan (MPC)
  description: Runs EMHASS MPC optimizer, generating an optimal energy plan

  run_dayahead_optim:
    alias: "Run day-ahead optimization"
    mode: single
    sequence:
      - service: rest_command.trigger_dayahead_optim

      - service: input_datetime.set_datetime
        target:
          entity_id: input_datetime.emhass_last_dayahead_run
        data:
          datetime: "{{ now().strftime('%Y-%m-%d %H:%M:%S') }}"

      - service: input_datetime.set_datetime
        target:
          entity_id: input_datetime.day_ahead_forecast_end
        data:
          timestamp: >
            {% set now_time = now() %}
            {% set minute_offset = 15 - (now_time.minute % 15) %}
            {% set next_interval = (now_time + timedelta(minutes=minute_offset)).replace(second=0, microsecond=0) %}

            {% set load_list = state_attr('sensor.nordpool_se3_total_costs_import', 'forecast_merged') or [] %}

            {% set future_load = load_list | selectattr('ts', '>=', next_interval.strftime('%Y-%m-%d %H:%M')) | list %}

            {% set horizon = [future_load | length, 96] | min %}

            {% if future_load %}
              {# Pad list if it has fewer than 96 entries #}
              {% set padded_list = (future_load[:horizon] + [future_load[-1]] * (96 - horizon))
                 if horizon < 96 else future_load[:horizon] %}

              {# Extract the timestamp from the range string #}
              {% set last_ts_str = padded_list[-1].ts.split(' - ')[0] %}
              {% set last_dt = last_ts_str | as_datetime %}
            {% else %}
              {# Fallback: +24h if no data #}
              {% set last_dt = next_interval + timedelta(hours=24) %}
            {% endif %}

            {{ as_timestamp(last_dt) }}
            
      - delay: "00:00:05"
      - service: rest_command.publish_data
  
  run_mpc_optimization:
    alias: "Run naive MPC optimization"
    sequence:
      - service: rest_command.trigger_mpc_optim
        data: {}
      - delay: "00:00:05"
      - service: rest_command.publish_data
    
  
  run_mlforecast_load_fit_and_predict:
    alias: "Run ML load Forecast Fit and Predict"
    sequence:
      - service: rest_command.mlforecast_fit_load
        data: {}
      - delay: "00:00:10"
      - service: rest_command.mlforecast_predict_load
        data: {}

  emhass_update_sliding_window:
    alias: "Update MPC Sliding Window Helpers"
    sequence:
      - variables:
          forecast_length: 96

        # Interval start rounded down to nearest 15 minutes
          interval_start: >
            {% set ct = now() %}
            {{ ct.replace(minute=(ct.minute // 15) * 15, second=0, microsecond=0) }}

        # Use the day-ahead optimization end timestamp
          forecast_end: >
            {% set dae = states('input_datetime.day_ahead_forecast_end') %}
            {{ (dae | as_datetime | as_local) - timedelta(minutes=15) }}

        # Remaining steps from now until end of forecast
          remaining_steps: >
            {% set delta_sec = (forecast_end | as_datetime) - (interval_start | as_datetime) %}
            {% set minutes = delta_sec.total_seconds() / 60 %}
            {% set ceil_steps = ((minutes + 14) // 15) | int %}
            {{ ceil_steps if ceil_steps > 0 else 1 }}

        # Calculate current step, end step, prediction horizon
          current_step: "{{ (forecast_length - remaining_steps) if (forecast_length - remaining_steps) >= 1 else 1 }}"
          end_step: "{{ forecast_length if (current_step + remaining_steps) > forecast_length else (current_step + remaining_steps) }}"
          prediction_horizon: "{{ (end_step - current_step + 1) }}"


      - service: input_number.set_value
        target:
          entity_id: input_number.mpc_window_start
        data:
          value: "{{ current_step | float(0) }}"

      - service: input_number.set_value
        target:
          entity_id: input_number.mpc_window_end
        data:
          value: "{{ end_step | float(0) }}"

      - service: input_number.set_value
        target:
          entity_id: input_number.mpc_prediction_horizon
        data:
          value: "{{ prediction_horizon | float(0) }}"
          

  set_mpc_soc_final_target:
    alias: "Set MPC SOC Final Target"
    sequence:
      # Step 1: Get fallback, end timestamp, and schedule
      - variables:
          fallback: 30
          end_ts: "{{ state_attr('input_datetime.day_ahead_forecast_end', 'timestamp') | int }}"
          schedule: "{{ state_attr('sensor.soc_batt_forecast', 'battery_scheduled_soc') or [] }}"

      # Step 2: Find the SOC value with the closest timestamp
      - variables:
          soc_target: >
            {% set result = fallback | float %}
            {% set min_diff = None %}
            {% for row in schedule %}
              {% if row is mapping and row.date is defined and row.soc_batt_forecast is not none %}
                {% set row_ts = as_timestamp(row.date) | int %}
                {% set diff = (row_ts - end_ts) | abs %}
                {% if min_diff is none or diff < min_diff %}
                  {% set min_diff = diff %}
                  {% set result = row.soc_batt_forecast | float %}
                {% endif %}
              {% endif %}
            {% endfor %}
            {{ result }}

      # Step 3: Clamp SOC safely between 0 and 100
      - variables:
          soc_target_clamped: >
            {% set soc_target_clamped = soc_target | float %}
            {% if soc_target_clamped < 0 %}
              {% set soc_target_clamped = 0 %}
            {% elif soc_target_clamped > 100 %}
              {% set soc_target_clamped = 100 %}
            {% endif %}
            {{ soc_target_clamped }}

      # Step 4: Write the value to the input_number
      - service: input_number.set_value
        target:
          entity_id: input_number.mpc_soc_final_target
        data:
          value: "{{ soc_target_clamped }}"

      # Step 5: Log the update
      - service: system_log.write
        data:
          message: "MPC SOC final target updated to {{ soc_target_clamped }} (closest timestamp match)."
          level: info
